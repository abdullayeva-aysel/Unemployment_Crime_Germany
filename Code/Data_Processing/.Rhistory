print(names(sgb2_raw))
############################################################
# 4) Try to detect ID, year, and SGB II columns automatically
############################################################
cols <- names(sgb2_raw)
# possible id columns (Kreis-Schlüssel)
id_candidates <- c("kreis_id", "kreisschluessel", "Kreisschlüssel",
"ags", "AGS", "RS", "rs", "district_key")
id_col <- id_candidates[id_candidates %in% cols]
if (length(id_col) == 0) {
stop("Could not detect a district ID column in SGB II file.
Please rename it manually in the code.")
} else {
id_col <- id_col[1]
}
