library(readr)
library(dplyr)
library(fixest)
library(readxl)
library(stringr)
############################################################
# 1) Load main panel (your existing dataset)
############################################################
panel <- read_csv("../../Data/Panel/final_panel_dataset.csv") %>%
mutate(
district_key   = as.character(district_key),
year           = as.integer(year),
log_crime_rate = log(crime_rate)
)
############################################################
# 2) Find and read the SGB II Excel file
############################################################
sgb2_path <- list.files(
"../../Data",
recursive  = TRUE,
pattern    = "sgb2_quote_2010_2023",
full.names = TRUE
)
if (length(sgb2_path) == 0) {
stop("Could not find a file containing 'sgb2_quote_2010_2023' under ../../Data")
}
print(sgb2_path)
# We know it's an xls/xlsx file
sgb2_raw <- read_excel(sgb2_path)
cat("\n--- SGB2 file columns ---\n")
print(names(sgb2_raw))
# You said: kennziffer, raumeinheit, aggregat, SGB-II - Quote
############################################################
# 3) Clean SGB II data (use your exact column names)
############################################################
# If there is an "aggregat" total row, we drop it:
sgb2_clean <- sgb2_raw %>%
# drop rows where aggregat is "aggregat" or NA
filter(!is.na(aggregat), aggregat != "aggregat") %>%
mutate(
# pad kennziffer to 5 digits to match district_key like "01001"
district_key = str_pad(as.character(kennziffer), width = 5, pad = "0"),
year         = as.integer(aggregat),
sgb2_quote   = as.numeric(`SGB-II - Quote`)
) %>%
select(district_key, year, sgb2_quote)
############################################################
# 0) Packages
############################################################
library(readr)
library(dplyr)
library(fixest)
library(readxl)
library(stringr)
############################################################
# 1) Load main panel (your existing dataset)
############################################################
panel <- read_csv("../../Data/Panel/final_panel_dataset.csv") %>%
mutate(
district_key   = as.character(district_key),
year           = as.integer(year),
log_crime_rate = log(crime_rate)
)
############################################################
# 2) Find and read the SGB II Excel file
############################################################
sgb2_path <- list.files(
"../../Data",
recursive  = TRUE,
pattern    = "sgb2_quote_2010_2023",
full.names = TRUE
)
if (length(sgb2_path) == 0) {
stop("Could not find a file containing 'sgb2_quote_2010_2023' under ../../Data")
}
print(sgb2_path)
# We assume it's an Excel file (.xlsx / .xls)
sgb2_raw <- read_excel(sgb2_path)
cat("\n--- SGB2 file columns ---\n")
print(names(sgb2_raw))
############################################################
# 3) Detect ID, year and SGB-II columns by pattern
############################################################
cols <- names(sgb2_raw)
# ID column: contains "kennziffer" (any case)
id_col <- cols[grepl("kennziffer", cols, ignore.case = TRUE)]
if (length(id_col) == 0) {
stop("Could not find an ID column containing 'kennziffer' in SGB2 file.")
} else {
id_col <- id_col[1]
}
# Year column: contains "aggregat" (any case)
year_col <- cols[grepl("aggregat", cols, ignore.case = TRUE)]
if (length(year_col) == 0) {
stop("Could not find a year column containing 'aggregat' in SGB2 file.")
} else {
year_col <- year_col[1]
}
# SGB-II quote column: contains "sgb" AND "quote"
sgb_col <- cols[
grepl("sgb", cols, ignore.case = TRUE) &
grepl("quote", cols, ignore.case = TRUE)
]
if (length(sgb_col) == 0) {
# fallback: any column containing "SGB" if "Quote" is not in the name
sgb_col <- cols[grepl("sgb", cols, ignore.case = TRUE)]
}
if (length(sgb_col) == 0) {
stop("Could not find a column for SGB-II quote in SGB2 file.")
} else {
sgb_col <- sgb_col[1]
}
cat("\nDetected in SGB2 file:\n")
cat("  ID   column: ", id_col,  "\n")
cat("  Year column: ", year_col, "\n")
cat("  SGB2 column: ", sgb_col,  "\n\n")
############################################################
# 4) Clean SGB II data
############################################################
sgb2_clean <- sgb2_raw %>%
mutate(
district_key = str_pad(as.character(.data[[id_col]]), width = 5, pad = "0"),
year         = as.integer(.data[[year_col]]),
sgb2_quote   = as.numeric(.data[[sgb_col]])
) %>%
select(district_key, year, sgb2_quote)
cat("\n--- Summary of SGB2 quote (clean) ---\n")
summary(sgb2_clean$sgb2_quote)
############################################################
# 5) Merge SGB II into main panel
############################################################
panel_ext <- panel %>%
left_join(sgb2_clean, by = c("district_key", "year"))
cat("\n--- After merge: SGB2 in panel ---\n")
summary(panel_ext$sgb2_quote)
cat("Years with non-missing SGB2:\n")
print(sort(unique(panel_ext$year[!is.na(panel_ext$sgb2_quote)])))
############################################################
# 6) Restrict to years with poverty data (2010–2023)
############################################################
panel_2010 <- panel_ext %>%
filter(year >= 2010, !is.na(sgb2_quote))
summary(panel_2010$year)
############################################################
# 7) FE model with unemployment + SGB II-Quote (poverty)
############################################################
mod_poverty <- feols(
log_crime_rate ~ unemployment_rate +
sgb2_quote +
gdp_per_capita +
share_youth_18_29 +
share_males +
school_leavers_no_qual |
district_key + year,
data    = panel_2010,
cluster = ~ district_key
)
# After building sgb2_clean
head(sgb2_clean)
# After merging:
head(panel_ext[, c("district_key", "year", "sgb2_quote")])
summary(panel_ext$sgb2_quote)
table(panel_ext$year[!is.na(panel_ext$sgb2_quote)])
