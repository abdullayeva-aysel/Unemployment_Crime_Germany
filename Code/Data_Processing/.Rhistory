library(readr)
library(dplyr)
library(fixest)
library(readxl)   # for .xlsx if needed
############################################################
# 1) Load main panel (your existing data)
############################################################
panel <- read_csv("../../Data/Panel/final_panel_dataset.csv") %>%
mutate(
district_key   = as.character(district_key),
year           = as.integer(year),
log_crime_rate = log(crime_rate)
)
############################################################
# 2) Locate the SGB II file automatically
############################################################
sgb2_path <- list.files(
"../../Data",
recursive  = TRUE,
pattern    = "sgb2_quote_2010_2023",
full.names = TRUE
)
if (length(sgb2_path) == 0) {
stop("Could not find a file containing 'sgb2_quote_2010_2023' under ../../Data")
}
print(sgb2_path)
############################################################
# 3) Read the SGB II file (CSV or XLSX)
############################################################
if (grepl("\\.csv$", sgb2_path, ignore.case = TRUE)) {
sgb2_raw <- read_csv(sgb2_path, show_col_types = FALSE)
} else if (grepl("\\.xlsx$", sgb2_path, ignore.case = TRUE)) {
sgb2_raw <- read_excel(sgb2_path)
} else {
stop("Found 'sgb2_quote_2010_2023' but it is neither CSV nor XLSX. Check the file type.")
}
