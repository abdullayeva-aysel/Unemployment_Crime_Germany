library(readr)
library(dplyr)
library(fixest)
# 1) Load final panel --------------------------------------
panel <- read_csv("../../Data/Panel/final_panel_dataset.csv") %>%
mutate(
district_key   = as.factor(district_key),
year           = as.integer(year),
log_crime_rate = log(crime_rate)
)
# Quick check (optional)
glimpse(panel)
summary(panel$sgb2_quote_2010_2023)
# Two-way FE: district + year, clustered SE at district level
mod_main <- feols(
log_crime_rate ~ unemployment_rate +
gdp_per_capita +
share_youth_18_29 +
share_males +
share_males_within_youth +
school_leavers_no_qual |
district_key + year,
data    = panel,
cluster = ~ district_key
)
summary(mod_main)
etable(
mod_main,
se          = "cluster",
cluster     = "district_key",
signif.code = c("***" = 0.01, "**" = 0.05, "*" = 0.1),
notes       = "* p < 0.1, ** p < 0.05, *** p < 0.01"
)
library(readr)
library(dplyr)
library(fixest)
# 1) Load final panel --------------------------------------
panel <- read_csv("../../Data/Panel/final_panel_dataset.csv") %>%
mutate(
district_key   = as.factor(district_key),
year           = as.integer(year),
log_crime_rate = log(crime_rate)
)
# Quick check (optional)
glimpse(panel)
summary(panel$sgb2_quote_2010_2023)
# Two-way FE: district + year, clustered SE at district level
mod_main <- feols(
log_crime_rate ~ unemployment_rate +
gdp_per_capita +
share_youth_18_29 +
share_males +
share_males_within_youth +
school_leavers_no_qual |
district_key + year,
data    = panel,
cluster = ~ district_key
)
summary(mod_main)
etable(
mod_main,
se          = "cluster",
cluster     = "district_key",
signif.code = c("***" = 0.01, "**" = 0.05, "*" = 0.1),
notes       = "* p < 0.1, ** p < 0.05, *** p < 0.01"
)
# Restrict to years where poverty is observed
panel_pov <- panel %>%
filter(year >= 2010, !is.na(sgb2_quote_2010_2023))
mod_poverty <- feols(
log_crime_rate ~ unemployment_rate +
sgb2_quote_2010_2023 +        # poverty
gdp_per_capita +
share_youth_18_29 +
share_males +
share_males_within_youth +
school_leavers_no_qual |
district_key + year,
data    = panel_pov,
cluster = ~ district_key
)
summary(mod_poverty)
etable(
mod_poverty,
se          = "cluster",
cluster     = "district_key",
signif.code = c("***" = 0.01, "**" = 0.05, "*" = 0.1),
notes       = "* p < 0.1, ** p < 0.05, *** p < 0.01"
)
