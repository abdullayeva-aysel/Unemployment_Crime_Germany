#' Extract transition map for a specific year step (Year T -> Year T+1)
get_transition_map <- function(ref_file, year_t) {
  year_t1 <- year_t + 1
  sheet_name <- paste0(year_t, "-", year_t1)

  sheets <- readxl::excel_sheets(ref_file)
  if (!sheet_name %in% sheets) {
    return(NULL)
  }

  data <- readxl::read_excel(ref_file, sheet = sheet_name)

  colnames(data) <- colnames(data) |>
    stringr::str_replace_all("[\r\n]+", " ") |>
    stringr::str_squish()

  col_name_t <- paste0("Kreise 31.12.", year_t)
  col_name_t1 <- paste0("Kreise 31.12.", year_t1)

  idx_t <- which(colnames(data) == col_name_t)
  idx_t1 <- which(colnames(data) == col_name_t1)

  if (length(idx_t) == 0 || length(idx_t1) == 0) {
    return(NULL)
  }

  weight_col_name <- colnames(data)[stringr::str_detect(
    colnames(data),
    "bevölkerungs.*Umsteige"
  )]
  if (length(weight_col_name) == 0) {
    weight_col_name <- colnames(data)[1] # Fallback (should not happen if logic matches)
    message("Warning: Using fallback weight column")
  } else {
    weight_col_name <- weight_col_name[1]
  }

  # Select columns
  transition <- data |>
    dplyr::select(
      old_id = dplyr::all_of(col_name_t),
      new_id = dplyr::all_of(col_name_t1),
      weight = dplyr::all_of(weight_col_name),
      old_name = dplyr::all_of(paste0("Kreisname ", year_t)),
      new_name = dplyr::all_of(paste0("Kreisname ", year_t1))
    ) |>
    dplyr::mutate(
      old_id = as.character(as.integer(old_id)),
      new_id = as.character(as.integer(new_id)),
      weight = as.numeric(weight)
    ) |>
    dplyr::filter(!is.na(old_id) & !is.na(new_id))

  # Safe Normalization with Threshold
  # Prevent data inflation if a major split part is missing.
  # Threshold 0.95: Only normalize if >= 95% of data is present (covers Mayen-Koblenz ~2% issue).

  trans_summary <- transition |>
    group_by(old_id) |>
    summarise(total_w = sum(weight), .groups = "drop") |>
    filter(total_w < 0.95)

  if (nrow(trans_summary) > 0) {
    warning(sprintf(
      "    ! Major Missing Data Risk: %d districts have Total Weight < 0.95. NOT Normalizing these to avoid inflation:",
      nrow(trans_summary)
    ))
    print(head(trans_summary))
  }

  transition <- transition |>
    group_by(old_id) |>
    mutate(total_w = sum(weight)) |>
    ungroup() |>
    mutate(
      # Apply normalization ONLY if total_w >= 0.95
      weight = ifelse(total_w >= 0.95, weight / total_w, weight)
    ) |>
    select(-total_w)

  clean_id <- function(x) {
    s <- sprintf("%08d", as.numeric(x))
    substr(s, 1, 5)
  }

  transition <- transition |>
    mutate(
      old_id = clean_id(old_id),
      new_id = clean_id(new_id)
    )

  return(transition)
}


#' Harmonize a dataset from a source year to target year
harmonize_dataset <- function(data, year_src) {
  current_data <- data
  # Capture original column order to restore later
  orig_names <- names(data)

  # --- Boundary Year Adjustments ---
  # Some PKS years use the boundaries of Jan 1st (Start of Year) instead of Dec 31st (End of Year).
  # If a major territorial reform happened MID-YEAR (e.g. Sachsen 2008, MV 2011),
  # the PKS data will use Old IDs, but the standard loop (Year -> Year+1) assumes End-Year IDs.
  # We must start mapping from the Previous Year to capture the reform.
  #
  # Sources for mid-year territorial reforms:
  # - Saxony 2008 (Aug 1): https://de.wikipedia.org/wiki/Kreisreform_Sachsen_2008
  # - Saxony-Anhalt 2007 (Jul 1): https://de.wikipedia.org/wiki/Kreisreform_Sachsen-Anhalt_2007
  # - Aachen 2009 (Oct 21): https://de.wikipedia.org/wiki/St%C3%A4dteregion_Aachen
  # - Mecklenburg-Vorpommern 2011 (Sep 4): https://de.wikipedia.org/wiki/Kreisgebietsreform_Mecklenburg-Vorpommern_2011
  # - Göttingen 2016 (Nov 1): https://de.wikipedia.org/wiki/Landkreis_G%C3%B6ttingen#Gebietsreform_2016
  # - Eisenach 2021 (Jul 1): https://de.wikipedia.org/wiki/Eisenach#Eingemeindung_in_den_Wartburgkreis

  effective_start_year <- year_src

  # 2008 PKS uses Start-2008 (aka End-2007) boundaries (Before Saxony Reform Aug 1, 2008)
  if (year_src == 2008) {
    effective_start_year <- 2007
  }

  # 2011 PKS uses Start-2011 (aka End-2010) boundaries (Before MV Reform Sep 4, 2011)
  if (year_src == 2011) {
    effective_start_year <- 2010
  }

  # 2009 PKS uses Start-2009 (aka End-2008) boundaries (Before Aachen Region creation Oct 21, 2009)
  # District 05313 (Aachen) merged into Städteregion Aachen (05334)
  if (year_src == 2009) {
    effective_start_year <- 2008
  }

  # 2016 PKS uses Start-2016 (aka End-2015) boundaries (Before Göttingen/Osterode merge Nov 1, 2016)
  if (year_src == 2016) {
    effective_start_year <- 2015
  }

  # 2021 PKS uses Start-2021 (aka End-2020) boundaries (Before Eisenach merge into Wartburgkreis Jul 1, 2021)
  if (year_src == 2021) {
    effective_start_year <- 2020
  }

  if (effective_start_year < target_year) {
    for (y in effective_start_year:(target_year - 1)) {
      map <- get_transition_map(ref_file, y)

      if (is.null(map)) {
        warning("    ! No transition map found for ", y)
        break
      }

      # Logging (Minimal)
      changes <- map |> filter(old_id != new_id | weight < 1.0)
      if (nrow(changes) > 0) {
        # Logging suppressed for performance
      }

      # Join
      # Clean Input IDs
      current_data <- current_data |>
        mutate(Kreisschluessel = stringr::str_trim(Kreisschluessel))

      # Join
      joined <- current_data |>
        left_join(
          map,
          by = c("Kreisschluessel" = "old_id"),
          relationship = "many-to-many"
        )

      # Handle Unmatched
      unmatched_rows <- joined |> filter(is.na(new_id))
      if (nrow(unmatched_rows) > 0) {
        missing_ids <- unique(unmatched_rows$Kreisschluessel)
        # Determine names if possible
        if ("Kreis" %in% names(unmatched_rows)) {
          missing_info <- unmatched_rows |>
            select(Kreisschluessel, Kreis) |>
            distinct() |>
            head(10)
          print(missing_info)
        }

        warning(sprintf(
          "    ! Dropping %d rows (Unmatched IDs). Examples: %s",
          nrow(unmatched_rows),
          paste(head(missing_ids, 5), collapse = ", ")
        ))

        joined <- joined |> filter(!is.na(new_id))
      }

      # --- Dynamic Column Identification ---
      # Exclude Keys and Weights
      exclude_cols <- c(
        "Kreisschluessel",
        "Schluesselzahl",
        "Straftat",
        "Kreis",
        "Kreisart",
        "old_id",
        "new_id",
        "weight",
        "old_name",
        "new_name",
        "total_w",
        "Jahr"
      )

      # Exclude Proportional Columns (Rates/Percentages)
      prop_patterns <- "_HZ$|_Prozent$|_quote$|Quote"

      # Identify Numeric Columns to Harmonize
      val_cols <- names(joined)[sapply(joined, is.numeric)]
      val_cols <- setdiff(val_cols, exclude_cols)
      val_cols <- val_cols[
        !stringr::str_detect(
          val_cols,
          stringr::regex(prop_patterns, ignore_case = TRUE)
        )
      ]

      # Verify we have columns to process
      if (length(val_cols) == 0) {
        warning("    ! No absolute value columns found to harmonize.")
      }

      # Weighting
      for (v in val_cols) {
        joined[[v]] <- joined[[v]] * joined$weight
      }

      # Aggregate
      # Group by Target ID and other non-spatial keys (Schluesselzahl, Straftat)
      current_data <- joined |>
        group_by(Schluesselzahl, Straftat, new_id) |>
        summarise(
          across(
            all_of(val_cols),
            \(x) if (all(is.na(x))) NA else sum(x, na.rm = TRUE)
          ),
          Kreis = first(new_name), # Take new name
          Kreisart = first(Kreisart),
          .groups = "drop"
        ) |>
        rename(Kreisschluessel = new_id)
    }
  }

  # --- Recalculate Rates (Post-Harmonization) ---
  # 1. Straftaten_HZ (Frequency)
  if (
    "Erfasste_Faelle" %in%
      names(current_data) &&
      "Einwohner" %in% names(current_data)
  ) {
    current_data <- current_data |>
      mutate(
        Straftaten_HZ = ifelse(
          Einwohner > 0,
          (Erfasste_Faelle / Einwohner * 100000),
          0
        )
      )
  }

  # 2. Aufklaerungsquote (Clearance Rate)
  if (
    "Aufklaerung_Faelle" %in%
      names(current_data) &&
      "Erfasste_Faelle" %in% names(current_data)
  ) {
    current_data <- current_data |>
      mutate(
        Aufklaerungsquote = ifelse(
          Erfasste_Faelle > 0,
          (Aufklaerung_Faelle / Erfasste_Faelle * 100),
          0
        )
      )
  }

  # 3. Versuche_Anteil_Prozent (Attempt Rate)
  if (
    "Versuche_Anzahl" %in%
      names(current_data) &&
      "Erfasste_Faelle" %in% names(current_data)
  ) {
    current_data <- current_data |>
      mutate(
        Versuche_Anteil_Prozent = ifelse(
          Erfasste_Faelle > 0,
          (Versuche_Anzahl / Erfasste_Faelle * 100),
          0
        )
      )
  }

  # 4. Nichtdeutsche_Tatverdaechtige_Prozent (Non-German Suspects Rate)
  if (
    "Nichtdeutsche_Tatverdaechtige_Anzahl" %in%
      names(current_data) &&
      "Tatverdaechtige_Insgesamt" %in% names(current_data)
  ) {
    current_data <- current_data |>
      mutate(
        Nichtdeutsche_Tatverdaechtige_Prozent = ifelse(
          Tatverdaechtige_Insgesamt > 0,
          (Nichtdeutsche_Tatverdaechtige_Anzahl /
            Tatverdaechtige_Insgesamt *
            100),
          0
        )
      )
  }
  # --- Restore Column Order ---
  # Enforce Standardized Master Order (based on 2023 format) for ALL years
  standard_col_order <- c(
    "Schluesselzahl",
    "Straftat",
    "Kreisschluessel",
    "Kreisart",
    "Kreis",
    "Einwohner",
    "Erfasste_Faelle",
    "Straftaten_HZ",
    "Versuche_Anzahl",
    "Versuche_Anteil_Prozent",
    "Mit_Schusswaffe_gedroht",
    "Mit_Schusswaffe_geschossen",
    "Aufklaerung_Faelle",
    "Aufklaerungsquote",
    "Tatverdaechtige_Insgesamt",
    "Tatverdaechtige_Maennlich",
    "Tatverdaechtige_Weiblich",
    "Nichtdeutsche_Tatverdaechtige_Anzahl",
    "Nichtdeutsche_Tatverdaechtige_Prozent"
  )

  final_cols <- names(current_data)

  # Determine order: Intersect(Standard, Final) + Any other columns (e.g., Einwohner)
  ordered_cols <- c(
    intersect(standard_col_order, final_cols),
    setdiff(final_cols, standard_col_order)
  )

  current_data <- current_data |>
    dplyr::arrange(Schluesselzahl, Kreisschluessel) |>
    dplyr::select(all_of(ordered_cols))

  return(current_data)
}

# --- Main Processing Loop ---

files <- list.files(input_dir, pattern = "\\.csv$", full.names = TRUE)
files <- files[stringr::str_detect(basename(files), "^20[0-9]{2}")]

message("===== STARTING UNIVERSAL HARMONIZATION =====")

for (f in files) {
  filename <- basename(f)
  year <- as.integer(stringr::str_extract(filename, "^20[0-9]{2}"))

  message(paste0("\n→ Processing: ", filename, " (Year: ", year, ")"))

  out_name <- paste0(year, "_PKS_harmonized.csv")
  out_path <- file.path(output_dir, out_name)
  if (file.exists(out_path)) {
    message("    ✓ Already exists. Skipping.")
    next
  }

  data <- read.csv(f, colClasses = "character") # Read all as char to safely handle IDs

  # Type enforcement for Legacy Process logic
  if ("Einwohner" %in% names(data)) {
    data$Einwohner <- as.numeric(data$Einwohner)
  }

  # Convert all potential numeric columns
  # We try to convert everything except checking specific exclusions
  # Or just iterate all and try to convert if they look numeric?
  # Safer: Convert specific known patterns or exclude known strings.
  # Actually, `read.csv(colClasses="character")` made everything char.
  # We must convert absolute columns to numeric for math.

  # Try to recover Einwohner if missing but HZ exists (Modern Data)
  # Try to recover Einwohner if missing or NA but HZ exists (Modern Data)
  # Check if Einwohner is missing OR if it is present but mostly NA/0
  einwohner_invalid <- FALSE
  if (!"Einwohner" %in% names(data)) {
    einwohner_invalid <- TRUE
  } else {
    # Check if >50% are NA or 0 (heuristic to trigger recovery)
    na_or_zero <- sum(is.na(data$Einwohner) | data$Einwohner == 0)
    if (na_or_zero > 0.5 * nrow(data)) {
      einwohner_invalid <- TRUE
    }
  }

  if (
    einwohner_invalid &&
      "Straftaten_HZ" %in% names(data) &&
      "Erfasste_Faelle" %in% names(data)
  ) {
    message("    ℹ Recovering 'Einwohner' from HZ and Case Counts...")

    # Force numeric conversion for these critical columns
    data$Straftaten_HZ <- suppressWarnings(as.numeric(data$Straftaten_HZ))
    data$Erfasste_Faelle <- suppressWarnings(as.numeric(
      data$Erfasste_Faelle
    ))

    # HZ = Cases / Pop * 100k  =>  Pop = Cases / HZ * 100k
    # Handle division by zero or NA
    data$Einwohner <- ifelse(
      !is.na(data$Straftaten_HZ) & data$Straftaten_HZ > 0,
      round(data$Erfasste_Faelle / data$Straftaten_HZ * 100000),
      NA
    )
  }

  exclude_conversion <- c(
    "Kreisschluessel",
    "Schluesselzahl",
    "Straftat",
    "Kreis",
    "Kreisart",
    "Jahr",
    "Schluessel",
    "Kreis_Type",
    "old_id",
    "new_id"
  )
  cols_to_convert <- setdiff(names(data), exclude_conversion)

  # Force conversion to numeric for all value columns
  # This ensures that read errors (treating numbers as chars) don't cause columns to be dropped during harmonization
  for (col in cols_to_convert) {
    data[[col]] <- suppressWarnings(as.numeric(data[[col]]))
  }

  # -------------------------------------------------------------------------
  # 2. Harmonize
  # -------------------------------------------------------------------------
  # Now input is standardized, so we can directly use it.

  # Ensure correct types for keys
  if ("Kreisschluessel" %in% names(data)) {
    data$Kreisschluessel <- as.character(data$Kreisschluessel)
  }

  # Process
  harmonized_data <- harmonize_dataset(
    data,
    year
  )
  out_name <- paste0(year, "_PKS_harmonized.csv")
  out_path <- file.path(output_dir, out_name)

  # Save with high precision
  old_digits <- getOption("digits")
  old_scipen <- getOption("scipen")
  options(digits = 22, scipen = 999)

  write.csv(harmonized_data, out_path, row.names = FALSE)

  options(digits = old_digits, scipen = old_scipen)

  # Validation
  n_rows <- nrow(harmonized_data)
  n_districts <- length(unique(harmonized_data$Kreisschluessel))
  has_na <- any(is.na(harmonized_data$Erfasste_Faelle))

  message("    ✓ Saved: ", out_name)
  message(
    "    ℹ Stats: Districts=",
    n_districts,
    " | Rows=",
    n_rows,
    " | NAs=",
    has_na
  )
}

