message("\n===== COMBINING AND FILTERING DATA =====")

harmonized_files <- list.files(output_dir, pattern = "\\.csv$", full.names = TRUE)
if (length(harmonized_files) > 0) {
  message("Combining ", length(harmonized_files), " yearly harmonized files...")
  
  # Read all files and add Year column if missing
  all_data_list <- purrr::map(harmonized_files, function(f) {
    df <- readr::read_csv(f, col_types = readr::cols(.default = "c"))
    # The year is usually in the filename (e.g., 2010_PKS_harmonized.csv)
    year_val <- as.integer(stringr::str_extract(basename(f), "^\\d{4}"))
    df$Year <- year_val
    return(df)
  })
  
  final_data <- dplyr::bind_rows(all_data_list)
  
  # Convert numeric columns
  num_cols <- c("Einwohner", "Erfasste_Faelle", "Straftaten_HZ", "Versuche_Anzahl", "Versuche_Anteil_Prozent",
                "Aufklaerung_Faelle", "Aufklaerungsquote", "Tatverdaechtige_Insgesamt",
                "Tatverdaechtige_Maennlich", "Tatverdaechtige_Weiblich", 
                "Nichtdeutsche_Tatverdaechtige_Anzahl", "Nichtdeutsche_Tatverdaechtige_Prozent")
  
  for (col in num_cols) {
    if (col %in% names(final_data)) {
      final_data[[col]] <- as.numeric(final_data[[col]])
    }
  }
  
  # We need Year, Crime_Code, Crime_Type, Kreisschluessel, Kreis, Einwohner, HZ
  # matching what downstream expects (`04_merge_final_panel.R` uses Crime_Code, Crime_Type, HZ)
  # So we rename: Schluesselzahl -> Crime_Code, Straftat -> Crime_Type, Straftaten_HZ -> HZ
  final_data <- final_data |>
    dplyr::rename(
      Crime_Code = Schluesselzahl,
      Crime_Type = Straftat,
      HZ = Straftaten_HZ
    )
    
  # INKAR data is not joined yet, however we have population ('Einwohner') from the PKS Excel itself
  # for those districts that had NA in HZ but valid Erfasste_Faelle.
  # Let's forcefully impute any missing HZ if we have both cases and population.
  final_data <- final_data |>
    dplyr::mutate(
      HZ = ifelse(is.na(HZ) & !is.na(Erfasste_Faelle) & !is.na(Einwohner) & Einwohner > 0,
                  (Erfasste_Faelle / Einwohner) * 100000,
                  HZ)
    )
  
  final_data <- final_data |>
    dplyr::arrange(Year, Kreisschluessel)
  
  message("Filtering to keep only crime types that exist in all historical years...")
  expected_years <- dplyr::n_distinct(final_data$Year)
  
  complete_crimes <- final_data |>
    dplyr::group_by(Crime_Code) |>
    dplyr::summarise(
      years_present = dplyr::n_distinct(Year),
      .groups = "drop"
    ) |>
    dplyr::filter(years_present == expected_years) |>
    dplyr::pull(Crime_Code)
  
  removed_crimes <- setdiff(unique(final_data$Crime_Code), complete_crimes)
  if (length(removed_crimes) > 0) {
    message(sprintf("Dropped %d crime types with incomplete historical coverage: %s", 
                    length(removed_crimes), paste(removed_crimes, collapse=", ")))
  }
  
  final_data <- final_data |>
    dplyr::filter(Crime_Code %in% complete_crimes) |>
    dplyr::arrange(Year, Kreisschluessel)
  
  final_combined_output <- file.path(dirname(output_dir), "extracted_pks_data_common_crime_types_harmonized.csv")
  readr::write_csv(final_data, final_combined_output)
  message("✓ Saved combined common crime types dataset to: ", final_combined_output)
}

