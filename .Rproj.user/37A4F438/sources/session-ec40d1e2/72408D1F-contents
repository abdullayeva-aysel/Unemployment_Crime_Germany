# Load necessary libraries
library(tidyverse)
library(kableExtra)

# 1. Load and filter the dataset
# Ensure the file is in your working directory
data <- read_csv("~/Applied_Economics/Data/Panel/final_panel_dataset_common_crimes.csv") %>%
  filter(crime_code == "------") %>%
  filter(year >= 2003, year <= 2022)

# 2. Define variables and professional labels
vars_of_interest <- c(
  "crime_rate", 
  "unemployment_rate", 
  "gdp_per_capita", 
  "share_youth_18_29",
  "share_males",
  "share_males_within_youth",
  "school_leavers_no_qual"
)

variable_labels <- c(
  "Crime Rate (per 100k)",
  "Unemployment Rate (%)",
  "GDP per Capita (€)",
  "Share of youth (18–29, %)",
  "Share of males (%)",
  "Male share among youth (%)",
  "Share of school leavers without qualifications (%)"
)

# 3. Process the data to create summary statistics
summary_stats <- data %>%
  select(all_of(vars_of_interest)) %>%
  pivot_longer(everything(), names_to = "Variable", values_to = "Value") %>%
  group_by(Variable) %>%
  summarise(
    Mean = mean(Value, na.rm = TRUE),
    SD = sd(Value, na.rm = TRUE),
    Min = min(Value, na.rm = TRUE),
    Max = max(Value, na.rm = TRUE),
    N = sum(!is.na(Value))
  ) %>%
  # Apply labels and maintain the specific order defined above
  mutate(Variable = factor(Variable, 
                          levels = vars_of_interest, 
                          labels = variable_labels)) %>%
  arrange(Variable)

# 4. Generate the LaTeX Table
latex_table <- summary_stats %>%
  kbl(
    format = "latex",
    booktabs = TRUE,
    caption = "Summary Statistics of Key Indicators",
    label = "tab:summary_stats",
    col.names = c("Variable", "Mean", "Std. Dev.", "Min", "Max", "Obs."),
    digits = 2,
    align = "lccccc",
    linesep = ""
  ) %>%
  kable_styling(
    latex_options = c("striped", "hold_position"),
    full_width = FALSE
  ) %>%
  add_header_above(c(" " = 1, "Descriptive Statistics" = 4, " " = 1)) %>%
  footnote(
    general = "Source: Computed from final_panel_dataset_common_crimes.csv. Observations from German district-level panel data.",
    fixed_small_size = TRUE
  )

# Print the LaTeX code to console
print(latex_table)